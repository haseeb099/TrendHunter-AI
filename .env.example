# =============================================================================
# DropHunter — Environment template
# Copy to .env and fill in values. See docs/API-ENV-SETUP.md for full guide.
# =============================================================================

NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Billing (optional — manual plan selection works without Stripe)
# When Stripe is configured, checkout + webhooks handle paid upgrades.
# Until then, keep Admin → Settings → Self-serve billing OFF (users upgrade via coupons/admin).
# APP_URL=http://localhost:3000
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_BUSINESS=
# STRIPE_PRICE_AGENCY=
# One-time credit top-ups (Stripe Payment mode)
# STRIPE_PRICE_CREDITS_50=
# STRIPE_PRICE_CREDITS_100=
# STRIPE_PRICE_CREDITS_250=
# Local webhooks: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Core (required)
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://trendhunter:trendhunter@127.0.0.1:3306/trendhunter
JWT_SECRET=local-dev-jwt-secret-change-me-in-production
APP_ID=trendhunter

# -----------------------------------------------------------------------------
# AI — validation, AI agent, social kit (OpenAI-compatible)
# OpenAI: https://platform.openai.com/api-keys
# Groq:   https://console.groq.com/keys (set GROQ_API_KEY only, or OPENAI_* for Groq base)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# GROQ_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# File storage — local uploads/ when S3 is not configured
# -----------------------------------------------------------------------------
UPLOADS_DIR=uploads
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://your-cdn.example.com

# -----------------------------------------------------------------------------
# Analytics (optional, frontend)
# -----------------------------------------------------------------------------
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# -----------------------------------------------------------------------------
# Free catalogs — no API key, no signup (always on unless disabled)
# DummyJSON + FakeStore + Shoptera (300 req/hr)
# -----------------------------------------------------------------------------
FREE_RETAIL_ENABLED=true
# SHOPTERA_ENABLED=true

# -----------------------------------------------------------------------------
# eBay Browse API — product search by marketplace
# Docs: https://developer.ebay.com
# -----------------------------------------------------------------------------
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=sandbox
# US: EBAY_US | UK: EBAY_GB | DE: EBAY_DE | AU: EBAY_AU | CA: EBAY_CA
EBAY_MARKETPLACE_ID=EBAY_US

# -----------------------------------------------------------------------------
# SerpAPI — Amazon + Google Shopping (+ optional trends/bestsellers)
# Docs: https://serpapi.com
# -----------------------------------------------------------------------------
SERPAPI_KEY=
# amazon.com | amazon.co.uk | amazon.de | amazon.fr
SERPAPI_AMAZON_DOMAIN=amazon.com
# Google Shopping locale (us, uk, de, fr, ...)
SERPAPI_GOOGLE_COUNTRY=us
SERPAPI_GOOGLE_LANGUAGE=en

# -----------------------------------------------------------------------------
# TikTok Shop — Option A: Official Partner API
# Docs: https://partner.tiktokshop.com
# -----------------------------------------------------------------------------
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_SHOP_CIPHER=
TIKTOK_API_VERSION=202405
TIKTOK_SHOP_REGION=US

# -----------------------------------------------------------------------------
# TikTok Shop — Option B: Third-party (use when official API unavailable)
# Providers: scrapecreators (default) | justoneapi
# -----------------------------------------------------------------------------
TIKTOK_SHOP_PROVIDER=scrapecreators
TIKTOK_SHOP_API_KEY=
# TIKTOK_SHOP_API_BASE=

# -----------------------------------------------------------------------------
# Product hunting — regions & trending (Sprint B+)
# -----------------------------------------------------------------------------
DEFAULT_REGION=US
SUPPORTED_REGIONS=US,UK,EU,GLOBAL
TRENDING_MAX_ITEMS=40

# -----------------------------------------------------------------------------
# CJ Dropshipping — supplier / warehouse / shipping (Sprint D+)
# Docs: https://developers.cjdropshipping.com
# -----------------------------------------------------------------------------
CJ_API_KEY=
# CJ_API_BASE=https://developers.cjdropshipping.com/api2.0/v1
# CJ_DEFAULT_WAREHOUSE=US

# -----------------------------------------------------------------------------
# AliExpress Open Platform — CN sourcing, ship-from, delivery (Sprint D+)
# Docs: https://openservice.aliexpress.com
# -----------------------------------------------------------------------------
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
# ALIEXPRESS_ACCESS_TOKEN=
# ALIEXPRESS_SHIP_FROM_DEFAULT=CN

# -----------------------------------------------------------------------------
# Redis — distributed rate limiting (optional; falls back to in-memory)
# Upstash: redis://default:TOKEN@HOST:6379
# -----------------------------------------------------------------------------
# REDIS_URL=  # strongly recommended in production (multi-instance rate limits)

# -----------------------------------------------------------------------------
# SearchAPI — TikTok Ad Library (optional; falls back to ScrapeCreators organic)
# https://www.searchapi.io/docs/tiktok-ads-library-api
# -----------------------------------------------------------------------------
# SEARCHAPI_KEY=
# TIKTOK_ADS_DAILY_CAP=10

# -----------------------------------------------------------------------------
# Data platform — daily ingest & cache-first search (Sprint 7+)
# GitHub Actions cron runs pnpm ingest:daily — see .github/workflows/daily-ingest.yml
# -----------------------------------------------------------------------------
TRENDING_CACHE_TTL_HOURS=24
SEARCH_CACHE_TTL_HOURS=24
OFFERS_CACHE_TTL_HOURS=24
INGEST_MODE=cache_first
SERPAPI_DAILY_CAP=3
META_ADS_DAILY_CAP=10
LIVE_SEARCH_REQUIRES_CREDITS=true
# Meta Ad Library — free with Facebook app (ads_read)
# META_ACCESS_TOKEN=
# INGEST_SECRET=  # optional HTTP trigger auth

# -----------------------------------------------------------------------------
# Email — rising keyword alerts & daily intel digest (Resend)
# https://resend.com/api-keys
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
# EMAIL_FROM=DropHunter <alerts@yourdomain.com>
# INTEL_DIGEST_ENABLED=true
# APP_URL=https://yourdomain.com  # required for email links (alerts, digest)

# -----------------------------------------------------------------------------
# Optional — multi-currency, deeper Amazon data (later)
# -----------------------------------------------------------------------------
# EXCHANGE_RATE_API_KEY=
# RAINFOREST_API_KEY=
# KEEPA_API_KEY=
