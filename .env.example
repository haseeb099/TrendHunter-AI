# =============================================================================
# DropHunter — Environment template
# Copy to .env and fill in values. See docs/API-ENV-SETUP.md for full guide.
# =============================================================================

NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Launch hardening (optional)
# SENTRY_DSN=                    # Server error monitoring
# VITE_SENTRY_DSN=               # Client error monitoring (build-time)
# BETA_MODE=false                # Require invite code on register
# BETA_INVITE_CODE=              # Required when BETA_MODE=true
# PASSWORD_RESET_TEST_MODE=false # Dev/test only: return reset token in forgotPassword response
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Billing (optional — manual plan selection works without Stripe)
# When Stripe is configured, checkout + webhooks handle paid upgrades.
# Until then, keep Admin → Settings → Self-serve billing OFF (users upgrade via coupons/admin).
# APP_URL=http://localhost:3000
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_BUSINESS=
# STRIPE_PRICE_AGENCY=
# One-time credit top-ups (Stripe Payment mode)
# STRIPE_PRICE_CREDITS_50=
# STRIPE_PRICE_CREDITS_100=
# STRIPE_PRICE_CREDITS_250=
# Local webhooks: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Google OAuth (optional — enable in Admin → Settings → Google sign-in)
# Create credentials: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {APP_URL}/api/auth/google/callback
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Core (required)
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://trendhunter:trendhunter@127.0.0.1:3306/trendhunter
JWT_SECRET=local-dev-jwt-secret-change-me-in-production
APP_ID=trendhunter

# -----------------------------------------------------------------------------
# AI — validation, AI agent, social kit (OpenAI-compatible)
# OpenAI: https://platform.openai.com/api-keys
# Groq:   https://console.groq.com/keys (set GROQ_API_KEY only, or OPENAI_* for Groq base)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# GROQ_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# File storage — local uploads/ when S3 is not configured
# -----------------------------------------------------------------------------
UPLOADS_DIR=uploads
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://your-cdn.example.com

# -----------------------------------------------------------------------------
# Analytics (optional, frontend)
# -----------------------------------------------------------------------------
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# -----------------------------------------------------------------------------
# Free catalogs — disabled by default for production truth mode
# DummyJSON + FakeStore; enable only for demo/QA (or set DEMO_MODE=true)
# Admin → Settings → Strict truth mode also gates catalog fallback
# -----------------------------------------------------------------------------
# FREE_RETAIL_ENABLED=false
# DEMO_MODE=false
# STRICT_TRUTH_MODE=true          # Production: force live-only data (overrides Admin strict_truth_mode)
# SHOPTERA_ENABLED=true          # Free Shopify/retail catalog (300 req/hr, ingest only)
# SHOPTERA_HOURLY_CAP=300

# -----------------------------------------------------------------------------
# RapidAPI — shared key for all free-tier marketplace APIs (ingest only)
# One key, separate monthly caps per API subscription
# -----------------------------------------------------------------------------
RAPIDAPI_KEY=
# RAPIDAPI_ENABLED=true
# RAPIDAPI_INGEST_MAX_PER_CYCLE=0   # 0 = use full per-provider daily/monthly/hourly budgets
# RAPIDAPI_PRODUCT_SEARCH_LIMIT=10

# Real-Time Amazon Data — category list (100/month)
# RAPIDAPI_AMAZON_HOST=real-time-amazon-data.p.rapidapi.com
RAPIDAPI_AMAZON_MONTHLY_CAP=100

# Real-Time Product Search — /search + /deals (100/month, limit=10 products/call)
# RAPIDAPI_PRODUCT_SEARCH_HOST=real-time-product-search.p.rapidapi.com
RAPIDAPI_PRODUCT_SEARCH_MONTHLY_CAP=100

# Google Search RapidAPI — discovery URLs (1000/month)
# RAPIDAPI_GOOGLE_SEARCH_HOST=google-search116.p.rapidapi.com
RAPIDAPI_GOOGLE_SEARCH_MONTHLY_CAP=1000

# Etsy API (45/month)
RAPIDAPI_ETSY_MONTHLY_CAP=45

# Pangolinfo Amazon Scraper (60/month)
RAPIDAPI_PANGOLINFO_MONTHLY_CAP=60

# Lazada DataHub image search (50/month)
RAPIDAPI_LAZADA_MONTHLY_CAP=50

# Taobao DataHub itemId utility (50/month — on-demand only)
RAPIDAPI_TAOBAO_MONTHLY_CAP=50

# Alibaba API health check (50/month — product search disabled on free tier)
RAPIDAPI_ALIBABA_MONTHLY_CAP=50

# New subscriptions (see docs/RAPIDAPI-SUBSCRIPTIONS.md)
RAPIDAPI_EBAY_DATA_MONTHLY_CAP=100
RAPIDAPI_AXESSO_WALMART_MONTHLY_CAP=50
RAPIDAPI_ALI_EXPRESS_DAILY_CAP=20
RAPIDAPI_ALI_EXPRESS_MONTHLY_CAP=600
RAPIDAPI_ALIEXPRESS_DATAHUB_MONTHLY_CAP=100
RAPIDAPI_WEB_SEARCH_MONTHLY_CAP=100
RAPIDAPI_NEWS_DATA_MONTHLY_CAP=100
RAPIDAPI_NEWS_API_MONTHLY_CAP=1000

# TikTok RapidAPI — shared RAPIDAPI_KEY, ingest-only monthly caps (100/mo BASIC free tier each)
# MediaCrawlers — User Media Feed by Username: GET /user/feed?username=
# RAPIDAPI_TIKTOK_SCRAPER_HOST=tiktok-api-fast-reliable-data-scraper.p.rapidapi.com
RAPIDAPI_TIKTOK_SCRAPER_MONTHLY_CAP=100
# RAPIDAPI_TIKTOK_SCRAPER_MAX_ITEMS=10
# Tikfly — keyword search + oldest posts: GET /api/search/video, /api/user/oldest-posts
# RAPIDAPI_TIKTOK_API_HOST=tiktok-api23.p.rapidapi.com
RAPIDAPI_TIKTOK_API_MONTHLY_CAP=100
# RAPIDAPI_TIKTOK_API_MAX_ITEMS=10

# -----------------------------------------------------------------------------
# eBay Browse API — product search by marketplace
# Docs: https://developer.ebay.com
# -----------------------------------------------------------------------------
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=sandbox
# US: EBAY_US | UK: EBAY_GB | DE: EBAY_DE | AU: EBAY_AU | CA: EBAY_CA
EBAY_MARKETPLACE_ID=EBAY_US

# -----------------------------------------------------------------------------
# SerpAPI — Amazon + Google Shopping (+ optional trends/bestsellers)
# Docs: https://serpapi.com
# -----------------------------------------------------------------------------
SERPAPI_KEY=
# Serper.dev — Google Shopping/Web/Images/News/Places (https://serper.dev/dashboard)
# Free tier: 2,500 credits/account/week — add multiple keys for rotation
SERPER_API_KEY=
# SERPER_API_KEYS=key2,key3,key4
SERPER_WEEKLY_CAP=2500
SERPER_INGEST_MAX_PER_CYCLE=40
# amazon.com | amazon.co.uk | amazon.de | amazon.fr
SERPAPI_AMAZON_DOMAIN=amazon.com
# Google Shopping locale (us, uk, de, fr, ...)
SERPAPI_GOOGLE_COUNTRY=us
SERPAPI_GOOGLE_LANGUAGE=en

# -----------------------------------------------------------------------------
# Just Serp API — Google Shopping + Google Trends (fallback alongside SerpAPI)
# Docs: https://docs.justserpapi.com
# Auth: X-API-Key header (create key in dashboard)
# -----------------------------------------------------------------------------
JUSTSERP_API_KEY=
# -----------------------------------------------------------------------------
# TikTok Shop — Option A: Official Partner API
# Docs: https://partner.tiktokshop.com
# -----------------------------------------------------------------------------
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_SHOP_CIPHER=
TIKTOK_API_VERSION=202405
TIKTOK_SHOP_REGION=US

# -----------------------------------------------------------------------------
# TikTok Shop — Option B: Third-party (use when official API unavailable)
# Providers: scrapecreators (default) | justoneapi
# -----------------------------------------------------------------------------
TIKTOK_SHOP_PROVIDER=scrapecreators
TIKTOK_SHOP_API_KEY=
# TIKTOK_SHOP_API_BASE=

# -----------------------------------------------------------------------------
# Product hunting — regions & trending (Sprint B+)
# -----------------------------------------------------------------------------
DEFAULT_REGION=US
SUPPORTED_REGIONS=US,UK,EU,GLOBAL
TRENDING_MAX_ITEMS=500

# -----------------------------------------------------------------------------
# CJ Dropshipping — supplier / warehouse / shipping + Discover live search (Sprint D+)
# Docs: https://developers.cjdropshipping.com
# CJ_API_KEY enables Discover → CJ platform filter and supplier offers.
# -----------------------------------------------------------------------------
CJ_API_KEY=
# CJ free tier: 1 req/s + points-based daily quota — ingest only (see docs/FREE-API-PROVIDERS.md)
# CJ_DAILY_POINTS_CAP=200
# CJ_MIN_INTERVAL_MS=1000
# CJ_API_BASE=https://developers.cjdropshipping.com/api2.0/v1
# CJ_DEFAULT_WAREHOUSE=US

# -----------------------------------------------------------------------------
# AliExpress Open Platform — CN sourcing, ship-from, delivery (Sprint D+)
# Docs: https://openservice.aliexpress.com
# -----------------------------------------------------------------------------
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
# ALIEXPRESS_ACCESS_TOKEN=
# ALIEXPRESS_SHIP_FROM_DEFAULT=CN

# -----------------------------------------------------------------------------
# Ropeship — fulfillment/branding API (optional integration point)
# -----------------------------------------------------------------------------
# ROPESHIP_API_KEY=
# ROPESHIP_API_BASE=

# -----------------------------------------------------------------------------
# Redis — distributed rate limiting (optional; falls back to in-memory)
# Upstash: redis://default:TOKEN@HOST:6379
# -----------------------------------------------------------------------------
# REDIS_URL=  # strongly recommended in production (multi-instance rate limits)

# -----------------------------------------------------------------------------
# SearchAPI — TikTok Ad Library (optional; falls back to ScrapeCreators organic)
# https://www.searchapi.io/docs/tiktok-ads-library-api
# -----------------------------------------------------------------------------
# SEARCHAPI_KEY=
# TIKTOK_ADS_DAILY_CAP=10

# -----------------------------------------------------------------------------
# Data platform — daily ingest & cache-first search (Sprint 7+)
# Automatic when DATABASE_URL is set:
#   - Trending queue every INGEST_TRENDING_INTERVAL_HOURS (default 1h), respects hourly API cap
#   - Full intel/catalog every INGEST_FULL_INTERVAL_HOURS (default 24h)
# Manual: pnpm ingest:trending  |  pnpm ingest:daily
# -----------------------------------------------------------------------------
TRENDING_CACHE_TTL_HOURS=24
TRENDING_MAX_ITEMS=200
TRENDING_MAX_ITEMS_CATEGORY=60
SEARCH_CACHE_TTL_HOURS=24
OFFERS_CACHE_TTL_HOURS=24
INGEST_MODE=cache_first
# INGEST_SCHEDULER_ENABLED=false   # set false to disable in-app auto ingest
INGEST_TRENDING_INTERVAL_HOURS=1
INGEST_FULL_INTERVAL_HOURS=24
INGEST_STARTUP_DELAY_MINUTES=5
INGEST_REGIONS=US,UK,EU,GLOBAL
INGEST_LIVE_SEARCH_BUDGET=60
INGEST_HOURLY_LIVE_SEARCH_BUDGET=300
INGEST_TRENDING_MAX_CATEGORIES=14
INGEST_TRENDING_QUERIES_DEFAULT=3
INGEST_TRENDING_QUERIES_PER_CATEGORY=2
DATA_RETENTION_DAYS=90
SERPAPI_DAILY_CAP=10
JUSTSERP_DAILY_CAP=10
META_ADS_DAILY_CAP=15
# Autonomous discovery queue (S17+)
DISCOVERY_QUEUE_MAX_PER_RUN=15
DISCOVERY_QUEUE_PRIORITY_MIN=0.4
# RANKING_VERSION=v3          # v1 = legacy, v2 = decision engine, v3 = launch weights (default)
# HEALTH_PROBE_EXTERNAL=true  # Optional deep health probes for eBay/SerpAPI/Meta
LIVE_SEARCH_REQUIRES_CREDITS=true
# Meta Ad Library (Facebook) — free with Meta app + ads_read permission
# Long-lived user token from Graph API Explorer; renew before expiry (~60 days)
# META_ACCESS_TOKEN=
# META_ADS_DAILY_CAP=100
# INGEST_SECRET=  # optional HTTP trigger auth

# -----------------------------------------------------------------------------
# Email — rising keyword alerts & daily intel digest (Resend)
# https://resend.com/api-keys
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
# EMAIL_FROM=DropHunter <alerts@yourdomain.com>
# INTEL_DIGEST_ENABLED=true
# APP_URL=https://yourdomain.com  # required for email links (alerts, digest)

# -----------------------------------------------------------------------------
# Optional — multi-currency, deeper Amazon data (later)
# -----------------------------------------------------------------------------
# EXCHANGE_RATE_API_KEY=
# RAINFOREST_API_KEY=
# KEEPA_API_KEY=
